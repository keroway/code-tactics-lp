---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  // 検索エンジンにインデックスさせないページ (例: 404) で true にする
  noindex?: boolean;
}

const {
  title = "code-tactics — ガンビット＆プログラムで AI 部隊を戦わせる 2D オートバトル",
  description = "戦車・ドローン・ミサイルなど複数ユニットの AI をガンビット UI またはテキストプログラムで設計し、自動戦闘を観察・分析・改善するプログラマブル・オートバトルゲーム。Web ブラウザで無料プレイ。",
  noindex = false,
} = Astro.props;

const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

// GitHub Pages のサブパス配信に対応。アセットは BASE_URL 前置で参照する。
const base = import.meta.env.BASE_URL;
// canonical / og:url は site + 現在パスから生成 (site 未設定時は undefined)
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
const ogImage = Astro.site
  ? new URL(`${base}/og.png`.replace(/\/+/g, "/"), Astro.site).href
  : undefined;

// 構造化データ (JSON-LD)。LP の主題はゲーム本体なので SoftwareApplication で表現する。
// author は本体ゲームの開発元 (keroway) を Organization として明示し、検索結果側で
// 制作者を辿れるようにする。
const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["SoftwareApplication", "VideoGame"],
  name: "code-tactics",
  applicationCategory: "GameApplication",
  genre: ["Strategy", "Simulation"],
  gamePlatform: ["Web browser", "Windows", "macOS", "Linux"],
  operatingSystem: "Web browser, Windows, macOS, Linux",
  playMode: "SinglePlayer",
  description,
  ...(canonical ? { url: canonical } : {}),
  ...(ogImage ? { image: ogImage } : {}),
  author: {
    "@type": "Organization",
    name: "keroway",
    url: "https://github.com/keroway",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "JPY",
  },
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* モバイルのブラウザ UI 色。favicon (#8) の背景色と揃え、accent(emerald) の土台となる暗色にする */
    }
    <meta name="theme-color" content="#0b1222" />
    {
      /* ダーク専用サイト。UA にダークを宣言し、ネイティブ UI(スクロールバー等)の暗色化と初期描画の白フラッシュ防止 */
    }
    <meta name="color-scheme" content="dark" />
    {noindex && <meta name="robots" content="noindex" />}
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <link
      rel="icon"
      type="image/svg+xml"
      href={`${base}/favicon.svg`.replace(/\/+/g, "/")}
    />
    <link
      rel="apple-touch-icon"
      href={`${base}/apple-touch-icon.png`.replace(/\/+/g, "/")}
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="code-tactics" />
    {
      /* og:locale はサイトの言語/地域を SNS クローラへ明示する。LP は日本語のみ。 */
    }
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {
      /* og:image は寸法 (1200x630, generate-og.mjs と一致) と alt を併記。
         SNS のカードを再フェッチ無しで正しく描画させ、代替テキストも提供する */
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta
            property="og:image:alt"
            content="code-tactics のプレイ画面: バトルフィールドの隣にガンビット (AI ルール) 編集 UI が並ぶ 2D プログラマブル・オートバトル"
          />
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
    {
      import.meta.env.PROD && cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
        />
      )
    }
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    {
      /* 本文へスキップ。通常は視覚的に隠し、キーボードフォーカス時のみ表示する */
    }
    <a
      href="#main"
      class="sr-only rounded-md bg-emerald-500 font-semibold text-slate-950 focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400"
    >
      本文へスキップ
    </a>
    <slot />
  </body>
</html>
