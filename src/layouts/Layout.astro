---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "code-tactics — AI ルールを組んで戦わせるオートバトル",
  description = "ユニットを直接操作せず、AI ルール (ガンビット式) を組んで自動戦闘させる 2D プログラマブル・オートバトルゲーム。負けた理由をログで分析し、ルールを直して再挑戦する。",
} = Astro.props;

// GitHub Pages のサブパス配信に対応。アセットは BASE_URL 前置で参照する。
const base = import.meta.env.BASE_URL;
// canonical / og:url は site + 現在パスから生成 (site 未設定時は undefined)
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
const ogImage = Astro.site
  ? new URL(`${base}/og.png`.replace(/\/+/g, "/"), Astro.site).href
  : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <slot />
  </body>
</html>
