---
// 特徴 / 魅力。
import FeatureCard from "./FeatureCard.astro";

const features = [
  {
    title: "ガンビット式 AI 設定",
    body: "条件と行動を優先順で並べるだけ。プログラミング不要で AI の挙動を組める。",
  },
  {
    title: "決定論シミュレーション",
    body: "同じ条件・同じ乱数シードなら必ず同じ結果。再現性があるから原因を特定できる。",
  },
  {
    title: "戦闘ログによる分析",
    body: "いつ・どのルールが発動し何が起きたかを時系列で確認。仮説 → 修正 → 検証のサイクル。",
  },
];
---

<section id="features" data-animate class="scroll-mt-20">
  <p class="eyebrow">features</p>
  <h2 class="mt-3 text-2xl font-bold sm:text-3xl">特徴</h2>
  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((f) => <FeatureCard title={f.title} body={f.body} />)}
  </div>
</section>
