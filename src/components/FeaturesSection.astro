---
// 特徴 / 魅力。
import FeatureCard from "./FeatureCard.astro";

const features = [
  {
    title: "ガンビット式 + プログラム UI",
    body: "条件と行動を優先順で並べるだけでも、テキスト構文でまとめて書くこともできる。どちらも同じ内部ルールに変換。",
  },
  {
    title: "複数ユニットと戦術要素",
    body: "軽戦車・重戦車・偵察ドローン・ミサイル車両、複数武器、障害物、射線、経路探索、地上/航空レイヤーに対応。",
  },
  {
    title: "ログとリプレイで分析",
    body: "同じ条件・同じシードなら同じ結果。ログ、発動履歴、リプレイ共有で、仮説 → 修正 → 検証を回せる。",
  },
];
---

<section id="features" data-animate class="scroll-mt-20">
  <p class="eyebrow">features</p>
  <h2 class="mt-3 text-2xl font-bold sm:text-3xl">特徴</h2>
  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((f) => <FeatureCard title={f.title} body={f.body} />)}
  </div>
</section>
