---
// 遊び方 3 ステップの 1 枚。番号 + 見出し + 本文。
interface Props {
  no: string;
  title: string;
  body: string;
}
const { no, title, body } = Astro.props;
---

<li class="rounded-lg border border-slate-800 bg-slate-900/50 p-6">
  <span class="font-mono text-sm text-emerald-400">{no}</span>
  <h3 class="mt-2 text-lg font-semibold">{title}</h3>
  <p class="mt-2 text-sm text-slate-300">{body}</p>
</li>
