---
// スクロール連動フェードイン (プログレッシブエンハンスメント)。
// IntersectionObserver 対応時のみ <html> に .js-fade を付けて初期非表示にし、
// viewport に入った要素へ .is-visible を付与する。JS 無効・IO 非対応時は
// .js-fade が付かず、CSS 側で [data-animate] は常に可視のまま (隠したまま残さない)。
// reduce 設定時は global.css 側のメディアクエリでフェード自体が無効化される。
---

<script is:inline>
  if ("IntersectionObserver" in window) {
    document.documentElement.classList.add("js-fade");
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
    );
    const observeAll = () =>
      document
        .querySelectorAll("[data-animate]")
        .forEach((el) => io.observe(el));
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", observeAll);
    } else {
      observeAll();
    }
  }
</script>
