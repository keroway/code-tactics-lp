---
// サイトフッター。ライセンス表記と最小限の回遊リンク。
import {
  PLAY_URL,
  REPO_URL,
  EXTERNAL_LINK_ATTRS,
  externalLinkLabel,
  withUtm,
} from "../consts";

const base = import.meta.env.BASE_URL;
const privacyUrl = `${base}/privacy`.replace(/\/+/g, "/");
---

<footer class="border-t border-slate-800">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-8 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between"
  >
    <p>code-tactics ―― 2D プログラマブル・オートバトル。MIT License.</p>
    <nav class="flex gap-4">
      <a href={privacyUrl} class="hover:text-slate-300">プライバシー</a>
      <a
        href={withUtm(PLAY_URL, "footer")}
        class="hover:text-slate-300"
        aria-label={externalLinkLabel("プレイ")}
        {...EXTERNAL_LINK_ATTRS}>プレイ</a
      >
      <a
        href={REPO_URL}
        class="hover:text-slate-300"
        aria-label={externalLinkLabel("GitHub")}
        {...EXTERNAL_LINK_ATTRS}>GitHub</a
      >
    </nav>
  </div>
</footer>
