---
// ヒーロー (ファーストビュー)。#top はヘッダのロゴからのスクロール先。
import {
  PLAY_URL,
  REPO_URL,
  REPO_IS_PUBLIC,
  EXTERNAL_LINK_ATTRS,
  externalLinkLabel,
  withUtm,
} from "../consts";
import { Image } from "astro:assets";
import gameScreenshot from "../assets/game-screenshot.png";
---

<section
  id="top"
  aria-labelledby="hero-heading"
  class="mx-auto flex max-w-5xl flex-col items-start gap-6 px-6 pt-24 pb-16"
>
  <p class="eyebrow">programmable auto-battle</p>
  <h1 id="hero-heading" class="text-4xl font-bold tracking-tight sm:text-6xl">
    自分で組んだ AI で、<br />戦車を戦わせる。
  </h1>
  <p class="max-w-2xl text-lg text-slate-300">
    ユニットは直接操作しない。戦う前に AI ルールを設計し、自動戦闘の結果とログを
    観察して、負けた理由を直していく ―― そんなサイクルが中核のオートバトル。
  </p>
  <div class="mt-2 flex flex-wrap gap-4">
    <a
      href={withUtm(PLAY_URL, "hero")}
      class="btn-primary"
      aria-label={externalLinkLabel("今すぐプレイ")}
      {...EXTERNAL_LINK_ATTRS}>今すぐプレイ</a
    >
    {
      REPO_IS_PUBLIC ? (
        <a
          href={REPO_URL}
          class="btn-ghost"
          aria-label={externalLinkLabel("GitHub を見る")}
          {...EXTERNAL_LINK_ATTRS}
        >
          GitHub を見る
        </a>
      ) : (
        <span class="btn-ghost-disabled" aria-disabled="true">
          GitHub（準備中）
        </span>
      )
    }
  </div>

  <figure
    aria-label="code-tactics のゲーム画面。左にルールエディタ（ガンビット）、中央に 2 体の戦車が接近する戦場キャンバス、下にリアルタイム戦闘ログ"
    class="mt-4 w-full overflow-hidden rounded-xl border border-slate-800 shadow-2xl"
  >
    <Image
      src={gameScreenshot}
      alt="code-tactics のゲーム全体画面。右パネルのガンビットエディタで AI ルールを設定し、中央キャンバスで 2 体の戦車（青・赤）が互いの射程に接近した場面"
      class="w-full"
      loading="eager"
    />
  </figure>
</section>
