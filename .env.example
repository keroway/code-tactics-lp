# Cloudflare Web Analytics のビーコントークン
# Cloudflare ダッシュボード > Web Analytics > サイト設定 から取得する
# 本番ビルド (PROD=true) のみ beacon.min.js が埋め込まれる
PUBLIC_CF_BEACON_TOKEN=your-token-here

# 本体リポジトリ (keroway/code-tactics) の公開状態 (issue #97)
# 本体が private の間は GitHub CTA が 404 になるため、未設定/false のときは
# CTA を「準備中」表示にして 404 を防ぐ。
# 本体を public 化したら "true" を設定するだけで通常の GitHub リンクへ戻る。
PUBLIC_REPO_PUBLIC=false
